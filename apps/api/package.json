{
  "name": "@taketrip/api",
  "private": true,
  "version": "0.1.0",
  "description": "Taketrip API — NestJS + Drizzle ORM + PostgreSQL",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest-integration.config.js --runInBand",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx seed/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "uuidv7": "1.2.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@eslint/js": "10.0.1",
    "@nestjs/testing": "11.1.27",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.0",
    "@types/pg": "8.15.6",
    "@types/supertest": "7.2.0",
    "drizzle-kit": "0.31.10",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "jest": "30.4.2",
    "prettier": "3.9.4",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsx": "4.20.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.1"
  }
}
