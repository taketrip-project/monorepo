# Copie para .env e ajuste se necessário. Valores abaixo já batem com docker-compose.yml.

# Banco de dev (docker compose)
DATABASE_URL=postgres://taketrip:taketrip@localhost:5432/taketrip

# Banco usado pelos testes de integração (mesmo container, base separada)
DATABASE_URL_TEST=postgres://taketrip:taketrip@localhost:5432/taketrip_test

# API
PORT=3333
JWT_SECRET=dev-secret-change-me

# URL do app web — usada só para montar links de e-mail (convite, redefinição de senha).
APP_URL=http://localhost:5173

# E-mail (SES) — módulo notifications. Sem estas variáveis, o envio vira
# apenas um log (dev/CI); PRECISA estar configurado em produção. Credenciais
# AWS vêm das variáveis padrão do SDK (AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY)
# ou de role da instância — não há variável própria do Taketrip para isso.
SES_REGION=us-east-1
SES_REMETENTE=

# Fotos de excursão (S3) — módulo excursions. Sem S3_BUCKET, as fotos são
# salvas localmente (diretório temporário do processo) em vez de no S3 de
# verdade — só para dev/CI/testes sem credenciais AWS; PRECISA estar
# configurado em produção. Credenciais AWS vêm das variáveis padrão do SDK,
# como em SES. S3_URL_BASE é a URL pública de leitura do bucket (domínio do
# bucket ou CloudFront na frente dele); default: https://<bucket>.s3.amazonaws.com.
S3_REGION=us-east-1
S3_BUCKET=
S3_URL_BASE=

# Web (Vite expõe apenas variáveis prefixadas com VITE_)
VITE_API_URL=http://localhost:3333/api/v1
